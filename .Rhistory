set.seed(123)
n <- 200
aa <- data.frame(
x1 = rnorm(n),
x2 = rnorm(n),
y = as.factor(sample(c(0, 1),
n, replace = TRUE))
)
train_model <- function(
model, data){
set.seed(123)
tran_index <- createDataPartition(data$y,
p = 0.7, list = FALSE)
train_data <- data[train_index, ]
test_data <- data[-train_index, ]
fit <- train(y ~ ., data = train_data, method = model)
predictions <- predict(fit, test_data)
accuracy <- confusionMatrix(predictions, test_data$y)$overall['Accuracy']
return(as.numeric(accuracy))
}
model_names <- c("glm", "rpart", "rf")
accuracies <- sapply(model_names, train_model, data = data)
