install.packages("echarts4r")
library(echarts4r)
library(dplyr)
# Install echarts4r if you haven't installed it already
# install.packages("echarts4r")
library(echarts4r)
library(dplyr)
# Create a dummy dataset to demonstrate the inverse relationship
set.seed(123)
years <- seq(2000, 2024, by = 1)
production <- seq(1, 50, length.out = length(years))  # Increase production
price <- 100 - (production * 1.5) + rnorm(length(production), 0, 5)  # Decrease price with some noise
data <- data.frame(
Year = years,
Production = production,
Price = price
)
# Create an animated scatter plot
data %>%
e_charts(Production, timeline = TRUE) %>%  # X-axis is production
e_scatter(Price, bind = Year) %>%  # Y-axis is price
e_labels(show = TRUE) %>%
e_x_axis(name = "Production (Million Barrels)", min = 0, max = 55) %>%
e_y_axis(name = "Crude Oil Price ($)", min = 0, max = 120) %>%
e_title("Inverse Relationship between Oil Production and Price",
subtext = "Year-by-Year Changes in Production and Price") %>%
e_timeline_opts(auto_play = TRUE, play_interval = 1000) %>%  # Timeline animation settings
e_tooltip(trigger = "axis") %>%
e_legend(show = FALSE) %>%
e_theme("infographic")  # Optional: change the theme
# Install echarts4r if you haven't installed it already
# install.packages("echarts4r")
library(echarts4r)
library(dplyr)
# Create a dummy dataset to demonstrate the inverse relationship
set.seed(123)
years <- seq(2000, 2024, by = 1)
production <- seq(1, 50, length.out = length(years))  # Increase production
price <- 100 - (production * 1.5) + rnorm(length(production), 0, 5)  # Decrease price with some noise
data <- data.frame(
Year = years,
Production = production,
Price = price
)
# Group data by Year for the timeline
grouped_data <- data %>%
group_by(Year) %>%
summarise(Production = mean(Production), Price = mean(Price), .groups = 'drop')
# Create an animated scatter plot
grouped_data %>%
e_charts(Production, timeline = TRUE) %>%  # X-axis is production
e_scatter(Price, bind = Year) %>%  # Y-axis is price
e_labels(show = TRUE) %>%
e_x_axis(name = "Production (Million Barrels)", min = 0, max = 55) %>%
e_y_axis(name = "Crude Oil Price ($)", min = 0, max = 120) %>%
e_title("Inverse Relationship between Oil Production and Price",
subtext = "Year-by-Year Changes in Production and Price") %>%
e_timeline_opts(auto_play = TRUE, play_interval = 1000) %>%  # Timeline animation settings
e_tooltip(trigger = "axis") %>%
e_legend(show = FALSE) %>%
e_theme("infographic")  # Optional: change the theme
